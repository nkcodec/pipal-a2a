{
  "name": "pipal-a2a",
  "version": "0.4.2",
  "description": "P2P multi-agent orchestration — each pi terminal IS an agent. Google A2A v1.0. Worktree isolation. v0.4.1 SQLite crash-safe.",
  "private": true,
  "type": "module",
  "main": "src/cli/index.ts",
  "scripts": {
    "start": "node src/cli/index.ts serve",
    "test": "vitest run",
    "agents": "NODE_NO_WARNINGS=1 npx tsx src/cli/index.ts agents",
    "health": "NODE_NO_WARNINGS=1 npx tsx src/cli/index.ts health",
    "serve": "NODE_NO_WARNINGS=1 npx tsx src/cli/index.ts serve"
  },
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "dependencies": {
    "express": "^4.18.2",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "tsx": "^4.22.0",
    "vitest": "^4.1.6"
  },
  "keywords": [
    "pi-package",
    "a2a",
    "agent",
    "multi-agent",
    "peer-to-peer",
    "orchestration",
    "pi-extension",
    "p2p"
  ],
  "license": "MIT"
}
